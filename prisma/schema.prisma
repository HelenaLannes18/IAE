// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// Usaremos SQLite para facilitar o desenvolvimento local
// Usaremos SQLite para facilitar o desenvolvimento local
datasource db {
  provider = "sqlite"
}

// Tabela de Usuários
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String? // hash da senha (bcrypt) - nullable pois usuários antigos não têm senha ainda
  role      String   @default("Autor")
  status    String   @default("Ativo")
  createdAt DateTime @default(now())
  posts     Post[]
}

// Tabela de Artigos do Blog
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  category  String
  status    String   @default("Rascunho") // Publicado, Rascunho
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação com o autor
  authorId Int
  author   User @relation(fields: [authorId], references: [id])
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  course    String? // programa de interesse selecionado no formulário
  createdAt DateTime @default(now())
}
